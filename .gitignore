# =============================================================================
# Environment & Secrets — NEVER commit real credentials
# =============================================================================
.env
.env.local
.env.*.local

# =============================================================================
# Python — build artifacts, caches, virtual environments
# =============================================================================
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# =============================================================================
# Vector Database — large binary store, git-ignored for size and reproducibility
# =============================================================================
chroma_langchain_db/
my_local_db/

# =============================================================================
# IDE & Editor — per-user config, never portable across machines
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# OS Artifacts — platform-specific clutter with zero engineering value
# =============================================================================
.DS_Store
Thumbs.db
Desktop.ini

# =============================================================================
# Logs — runtime noise, not source code
# =============================================================================
*.log

# =============================================================================
# Testing & Coverage — generated reports
# =============================================================================
.coverage
htmlcov/
.pytest_cache/
tests/__pycache__/